{
  "id": "姜炒鸡",
  "name": "姜炒鸡",
  "category": "荤菜",
  "difficulty": "中等",
  "tools": [
    "炒锅"
  ],
  "ingredients": [
    {
      "name": "鸡 = 半只（土鸡最好，预计",
      "amount": "650g）"
    },
    {
      "name": "食用油 =",
      "amount": "50ml（茶油最好，没有就用菜籽油）"
    },
    {
      "name": "生姜 = 半斤 (250g)",
      "amount": "适量"
    },
    {
      "name": "啤酒 = 半瓶",
      "amount": "250ml"
    },
    {
      "name": "生抽 =",
      "amount": "20ml"
    },
    {
      "name": "老抽 =",
      "amount": "10ml"
    },
    {
      "name": "盐 =",
      "amount": "3g"
    },
    {
      "name": "小米椒 =",
      "amount": "0-5 个 (0-50g)（根据辣口味调整）"
    },
    {
      "name": "美人辣 =",
      "amount": "0-5 个 (0-50g)（没有可以用小米椒代替）"
    },
    {
      "name": "泡椒 =",
      "amount": "5 个 (50g)"
    },
    {
      "name": "大蒜 =",
      "amount": "3 头 (50g)"
    }
  ],
  "steps": [
    "鸡尽量剁成 1cm 的小块，洗净后滤干，再放生抽腌和料酒腌制 30 分钟",
    "大先热锅到微微冒烟，放入食用油，等 5 秒",
    "下入姜片后转中火炒 30 秒，",
    "下入鸡块翻炒 3 分钟，炒干水分，炒出鸡油",
    "放入各种剁碎的辣椒和大蒜子，加盐和老抽继续翻炒 30 秒",
    "倒入啤酒，中小火焖 2 分钟",
    "大火收汁盛盘"
  ]
}
