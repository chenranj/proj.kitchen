{
  "id": "清蒸生蚝",
  "name": "清蒸生蚝",
  "category": "水产",
  "difficulty": "中等",
  "tools": [
    "蒸锅"
  ],
  "ingredients": [
    {
      "name": "饮用水",
      "amount": "1 升"
    },
    {
      "name": "生蚝",
      "amount": "6 个"
    },
    {
      "name": "葱",
      "amount": "3 颗"
    },
    {
      "name": "蒜",
      "amount": "6 瓣"
    },
    {
      "name": "姜",
      "amount": "1 小块"
    },
    {
      "name": "酱油 每个生蚝",
      "amount": "1 ml"
    }
  ],
  "steps": [
    "将生蚝用刷子刷干净（没有刷子用牙刷）。",
    "蒸锅中放水，将蒸屉放上之后，将 6 个生蚝平铺在蒸屉,使用 50%功率，蒸 3 分钟。",
    "用右手拿着湿抹布掀开烫锅盖，将每个生蚝的外壳掀开一半去掉，生蚝的凸面向下，平面向上，每个放 1 根姜丝,10g 蒜末放到生蚝上。",
    "关上烫锅盖，100%功率蒸 3.5 分钟。",
    "停火，用右手拿着抹布掀开烫锅盖，每个放 5ml 酱油。",
    "盛盘。"
  ]
}
