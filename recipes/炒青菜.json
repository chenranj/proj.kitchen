{
  "id": "炒青菜",
  "name": "炒青菜",
  "category": "素菜",
  "difficulty": "简单",
  "tools": [
    "炒锅"
  ],
  "ingredients": [
    {
      "name": "青菜",
      "amount": "100g/份"
    },
    {
      "name": "蒜瓣",
      "amount": "2 粒/份"
    },
    {
      "name": "食用油",
      "amount": "10-15ml（覆盖锅底即可）"
    },
    {
      "name": "食盐",
      "amount": "2g/份"
    },
    {
      "name": "饮用水",
      "amount": "70ml/份"
    },
    {
      "name": "白糖",
      "amount": "5g/份"
    }
  ],
  "steps": [
    "青菜掰成小瓣，用清水洗净，备用。",
    "将蒜瓣剁碎，备用",
    "中火或大火热锅后，锅内放入 10-15ml 食用油。再等待 30 秒让油温升高。",
    "将准备好的青菜倒入锅中，翻炒至青菜变软（约 1 分钟）。",
    "放入剁碎的蒜瓣",
    "倒入计算好的清水，水位应当完全浸润或即将没过青菜，加入食盐 （2g * 份数），继续翻炒约 1 分钟。",
    "最后加入白糖小火加热 2 分钟，加热时盖上锅盖。",
    "盛盘。"
  ]
}
