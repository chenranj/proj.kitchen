{
  "id": "蒜蓉虾",
  "name": "蒜蓉虾",
  "category": "水产",
  "difficulty": "简单",
  "tools": [
    "蒸锅"
  ],
  "ingredients": [
    {
      "name": "海虾",
      "amount": "8 只"
    },
    {
      "name": "蒜蓉酱",
      "amount": "50 g"
    },
    {
      "name": "食用油",
      "amount": "20 ml"
    },
    {
      "name": "生抽",
      "amount": "5 ml"
    }
  ],
  "steps": [
    "用刀从从虾头中间切开，切到距离虾尾 1 cm",
    "将蒜蓉酱铺在虾身中间，放在盘子中",
    "锅中倒入热水，将盘子放入锅中，大火蒸 3 分钟",
    "烧热油，倒入虾盘中，倒入生抽"
  ]
}
