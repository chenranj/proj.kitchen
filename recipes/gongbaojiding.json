{
  "id": "gongbaojiding",
  "name": "宫保鸡丁",
  "category": "川菜",
  "difficulty": "中等",
  "tools": ["炒锅"],
  "ingredients": [
    { "name": "鸡胸肉", "amount": "300g" },
    { "name": "花生米", "amount": "50g" },
    { "name": "干辣椒", "amount": "8个" },
    { "name": "花椒", "amount": "1茶匙" },
    { "name": "葱白", "amount": "2根" },
    { "name": "蒜", "amount": "3瓣" },
    { "name": "姜", "amount": "3片" },
    { "name": "生抽", "amount": "1汤匙" },
    { "name": "香醋", "amount": "1汤匙" },
    { "name": "白糖", "amount": "1汤匙" },
    { "name": "水淀粉", "amount": "1汤匙" },
    { "name": "料酒", "amount": "1汤匙" }
  ],
  "steps": [
    "鸡胸肉切1.5厘米丁，加料酒、生抽、水淀粉抓匀腌制15分钟。",
    "调碗汁：生抽、香醋、白糖、水淀粉混合均匀。",
    "花生米小火炒至金黄酥脆，盛出备用。",
    "锅中油烧至七成热，放入花椒和干辣椒段小火炒香。",
    "放入鸡丁大火快炒至变色。",
    "加入姜片、蒜片、葱白段翻炒出香味。",
    "倒入碗汁快速翻炒均匀，收汁。",
    "关火后加入花生米翻拌均匀。"
  ],
  "tips": "花生米关火后再加，保持酥脆口感；碗汁提前调好可以快速完成出锅。"
}
