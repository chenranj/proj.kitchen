    },
    {
      "name": "盐：5-8 克",
      "amount": "适量"
    },
    {
      "name": "老抽：3ml",
      "amount": "适量"
    },
    {
      "name": "生抽：6ml",
      "amount": "适量"
    },
    {
      "name": "桂皮：1 块",
      "amount": "适量"
    },
    {
      "name": "八角：3 个",
      "amount": "适量"
    },
    {
      "name": "郫县豆瓣酱：20 克",
      "amount": "适量"
    },
    {
      "name": "干辣椒：4-6 个（根据个人口味选择）",
      "amount": "适量"
