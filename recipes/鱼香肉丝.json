    },
    {
      "name": "青椒 100g",
      "amount": "适量"
    },
    {
      "name": "木耳（干） 5g",
      "amount": "适量"
    },
    {
      "name": "生抽 10ml",
      "amount": "适量"
    },
    {
      "name": "料酒 5ml",
      "amount": "适量"
    },
    {
      "name": "蛋清 1 个",
      "amount": "适量"
    },
    {
      "name": "淀粉 10g",
      "amount": "适量"
    },
    {
      "name": "醋 15ml",
      "amount": "适量"
    },
    {
      "name": "白糖 10g",
      "amount": "适量"
    },
    {
      "name": "盐 5g",
      "amount": "适量"
    },
    {
      "name": "姜 20g",
      "amount": "适量"
    },
    {
      "name": "葱 20g",
      "amount": "适量"
    },
    {
      "name": "蒜 2 瓣",
