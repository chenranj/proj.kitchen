{
  "id": "松仁玉米",
  "name": "松仁玉米",
  "category": "素菜",
  "difficulty": "简单",
  "tools": [
    "炒锅"
  ],
  "ingredients": [
    {
      "name": "玉米粒",
      "amount": "200 g（可用罐头甜玉米，也可自备煮熟）"
    },
    {
      "name": "熟松子仁",
      "amount": "30 g"
    },
    {
      "name": "胡萝卜",
      "amount": "50 g（切小丁，可省略）"
    },
    {
      "name": "食用油",
      "amount": "15 ml"
    },
    {
      "name": "白砂糖",
      "amount": "10 g"
    },
    {
      "name": "盐",
      "amount": "1 g"
    },
    {
      "name": "淀粉",
      "amount": "5 g"
    },
    {
      "name": "水",
      "amount": "20 ml（用于调淀粉水）"
    }
  ],
  "steps": [
    "玉米粒和胡萝卜丁提前焯水 1 分钟，捞出沥干备用",
    "热锅凉油，放入胡萝卜丁略炒，再加入玉米粒翻炒",
    "加入白砂糖和盐，炒匀",
    "混合水与淀粉成水淀粉，倒入锅中快速翻炒使汤汁略稠",
    "加入熟松仁翻炒均匀",
    "出锅装盘"
  ],
  "tips": "松仁可以提前用小火干炒至微微金黄香脆，更加美味；使用罐头玉米时应先沥干水分，避免炒制过程中出水过多；炒制时火候不宜过大，以防糊锅或松仁焦糊"
}
