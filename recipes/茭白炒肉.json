{
  "id": "茭白炒肉",
  "name": "茭白炒肉",
  "category": "荤菜",
  "difficulty": "中等",
  "tools": [
    "炒锅"
  ],
  "ingredients": [
    {
      "name": "茭白",
      "amount": "2 根"
    },
    {
      "name": "瘦肉",
      "amount": "100 g"
    },
    {
      "name": "淀粉",
      "amount": "15 g"
    },
    {
      "name": "食用油",
      "amount": "30 ml"
    },
    {
      "name": "鸡精",
      "amount": "5 g"
    },
    {
      "name": "姜",
      "amount": "1 片"
    },
    {
      "name": "蒜",
      "amount": "1 个"
    },
    {
      "name": "料酒",
      "amount": "5 ml"
    },
    {
      "name": "盐",
      "amount": "2 g"
    }
  ],
  "steps": [
    "茭白切片，每片厚度 0.5 cm",
    "瘦肉切条，厚度 0.3-0.5 cm，加入料酒、生粉、盐、水搅拌",
    "姜切片、蒜头剁碎",
    "起锅水烧开，放入茭白，水煮 60-90 S 后取出沥干",
    "起锅，倒入 15 ml 油，倒入瘦肉，反复翻炒 60 S 取出",
    "起锅，倒入 15 ml 油，倒入姜、蒜翻炒 30S，加入茭白继续翻炒 30 S",
    "继续加入瘦肉翻炒 60 S，加入 20 ml 水，加入盐、鸡精后翻炒 60S 出锅"
  ],
  "tips": "最后一个步骤，可以考虑加蚝油、生抽代替盐上色"
}
