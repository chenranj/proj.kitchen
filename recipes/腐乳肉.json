      "name": "带皮五花肉",
      "amount": "400 g"
    },
    {
      "name": "红腐乳",
      "amount": "30 g（约 2 块）"
    },
    {
      "name": "腐乳汁",
      "amount": "15 ml"
    },
    {
      "name": "冰糖",
      "amount": "25 g"
    },
    {
      "name": "老抽",
      "amount": "5 ml"
    },
    {
      "name": "料酒",
      "amount": "15 ml"
    },
    {
      "name": "葱白",
      "amount": "15 g"
    },
    {
      "name": "葱花",
      "amount": "5 g"
    },
    {
      "name": "生姜",
      "amount": "10 g"
    },
    {
      "name": "清水",
      "amount": "500 ml"
    },
    {
      "name": "食用油",
      "amount": "10 ml"
    }
  ],
  "steps": [
    "五花肉切成长宽 2.5 cm 的小块",
    "冷水放料酒姜片，五花肉放入开火慢慢加入到水沸腾后捞出",
    "玫瑰腐乳块和腐乳汁碾成泥，加冰糖、老抽调成酱汁",
    "热锅冷油爆香葱姜，下肉块煸到金黄",
    "倒入腐乳酱炒匀加热水焖煮",
    "小火慢炖 40 分钟",
    "大火收汁，看到汤汁冒浓稠鱼眼泡时关火"
  ],
  "tips": "建议用单晶冰糖；腐乳自带咸鲜，不用额外放盐；大火收汁时要不断晃动锅体避免粘底；参考资料：[【步骤图】腐乳肉的做法_腐乳肉的做法步骤_菜谱_下厨房](https://www.xiachufang.com/recipe/102507/)"
