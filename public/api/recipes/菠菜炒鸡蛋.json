{
  "id": "菠菜炒鸡蛋",
  "name": "菠菜炒鸡蛋",
  "category": "素菜",
  "difficulty": "简单",
  "tools": [
    "炒锅"
  ],
  "ingredients": [
    {
      "name": "菠菜",
      "amount": "350g"
    },
    {
      "name": "鸡蛋",
      "amount": "2 个"
    },
    {
      "name": "食用油",
      "amount": "15ml"
    },
    {
      "name": "食用盐",
      "amount": "5g"
    }
  ],
  "steps": [
    "菠菜去根，洗净，放在篮子里，焯水",
    "将鸡蛋打入碗中，搅匀",
    "热锅，加入 10ml 油",
    "油热后，倒入鸡蛋液，中火翻炒 15 秒，先煎成蛋饼，然后再用锅铲切成小块",
    "关火，将鸡蛋块 盛到盘子中，不要洗锅",
    "重新开火，倒入 5ml 油，油热后，放入菠菜，大火 翻炒 15 秒后，倒入鸡蛋块，翻炒均匀",
    "加入 5g 盐、100ml 饮用水，大火 翻炒 10 秒",
    "关火，盛盘"
  ]
}