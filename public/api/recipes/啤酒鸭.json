{
  "id": "啤酒鸭",
  "name": "啤酒鸭",
  "category": "荤菜",
  "difficulty": "中等",
  "tools": [
    "炒锅"
  ],
  "ingredients": [
    {
      "name": "鸭肉半只（约",
      "amount": "1kg）"
    },
    {
      "name": "啤酒",
      "amount": "800ml"
    },
    {
      "name": "生抽酱油",
      "amount": "10-15ml"
    },
    {
      "name": "老抽酱油",
      "amount": "5-10ml"
    },
    {
      "name": "姜",
      "amount": "5 片"
    },
    {
      "name": "蒜头",
      "amount": "12 瓣"
    },
    {
      "name": "冰糖",
      "amount": "10g"
    },
    {
      "name": "干辣椒",
      "amount": "5 个"
    },
    {
      "name": "料酒",
      "amount": "30ml"
    },
    {
      "name": "盐",
      "amount": "8g"
    },
    {
      "name": "鸡精",
      "amount": "5g"
    },
    {
      "name": "丁香",
      "amount": "4 颗"
    },
    {
      "name": "八角",
      "amount": "3 个"
    },
    {
      "name": "香叶",
      "amount": "3 片"
    },
    {
      "name": "豆瓣酱",
      "amount": "20g"
    }
  ],
  "steps": [
    "把鸭子切成 3 cm 小块，鸭肉冷水下锅，加姜片、料酒，焯一遍水，盛出沥干水分，备用。",
    "炒锅烧热，放入约 100ml 食用油，大火待油烧开，鸭肉入锅翻炒至上色。",
    "待鸭肉完全变色（肉眼可见泛白），将鸭肉拨到锅的一边，倒入豆瓣酱和糖，小火翻炒出香味和糖色。",
    "加入丁香、八角、香叶、干辣椒、生抽、老抽、蒜，翻炒出香味。",
    "倒入啤酒，没过鸭肉，加入盐、鸡精，然后中火将鸭子烧 30 分钟（牙口不好的话可以再多烧 5 分钟）。",
    "出锅盛盘，上桌食用。"
  ],
  "tips": "啤酒的量一定要足够把所有鸭肉没过，啤酒最好选择清香型的。"
}