{
  "id": "fanqiechaodan",
  "name": "番茄炒蛋",
  "category": "家常菜",
  "difficulty": "简单",
  "tools": [
    "炒锅"
  ],
  "ingredients": [
    {
      "name": "鸡蛋",
      "amount": "3个"
    },
    {
      "name": "番茄",
      "amount": "2个"
    },
    {
      "name": "白糖",
      "amount": "1茶匙"
    },
    {
      "name": "盐",
      "amount": "适量"
    },
    {
      "name": "葱花",
      "amount": "适量"
    },
    {
      "name": "食用油",
      "amount": "适量"
    }
  ],
  "steps": [
    "番茄顶部划十字，开水烫30秒后去皮，切成小块。",
    "鸡蛋打入碗中，加少许盐搅散。",
    "锅中多放些油烧热，倒入蛋液，待底部凝固后用铲子划散成大块，盛出备用。",
    "锅中留底油，放入番茄块，中火翻炒至出汁变软。",
    "加入白糖和盐调味，倒回炒好的鸡蛋翻炒均匀。",
    "撒上葱花出锅。"
  ],
  "tips": "炒蛋时油温要够高，蛋才会蓬松；番茄要炒出汁水味道才好。"
}