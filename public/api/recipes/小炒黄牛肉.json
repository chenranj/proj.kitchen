{
  "id": "小炒黄牛肉",
  "name": "小炒黄牛肉",
  "category": "荤菜",
  "difficulty": "中等",
  "tools": [
    "炒锅"
  ],
  "ingredients": [
    {
      "name": "牛里脊",
      "amount": "400g"
    },
    {
      "name": "芹菜",
      "amount": "200g"
    },
    {
      "name": "小米椒",
      "amount": "30g"
    },
    {
      "name": "野山椒",
      "amount": "30g"
    },
    {
      "name": "香菜",
      "amount": "30g"
    },
    {
      "name": "食用油",
      "amount": "15ml"
    },
    {
      "name": "酱油",
      "amount": "6ml"
    }
  ],
  "steps": [
    "牛里脊切成不超过 3cm 宽，3mm 厚的薄片，倒入 6ml 酱油，用手抓匀备用",
    "芹菜切成不超过 5cm 的小段，备用",
    "小米椒切成丝状，备用",
    "野山椒切成颗粒，备用",
    "香菜切成成不超过 3cm 的小段，备用",
    "热锅，锅内放入 15ml 食用油，大火等待 30 秒让油温升高",
    "放入小米椒和野山椒爆香",
    "放入牛里脊和芹菜，然后**大火翻炒 1 分钟**",
    "关火，撒上香菜，盛盘"
  ],
  "tips": "操作时，全程需要开大火"
}