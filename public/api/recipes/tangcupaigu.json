{
  "id": "tangcupaigu",
  "name": "糖醋排骨",
  "category": "家常菜",
  "difficulty": "中等",
  "tools": [
    "炒锅"
  ],
  "ingredients": [
    {
      "name": "小排",
      "amount": "500g"
    },
    {
      "name": "白糖",
      "amount": "3汤匙"
    },
    {
      "name": "香醋",
      "amount": "2汤匙"
    },
    {
      "name": "生抽",
      "amount": "2汤匙"
    },
    {
      "name": "料酒",
      "amount": "1汤匙"
    },
    {
      "name": "番茄酱",
      "amount": "1汤匙"
    },
    {
      "name": "姜",
      "amount": "3片"
    },
    {
      "name": "白芝麻",
      "amount": "适量"
    }
  ],
  "steps": [
    "小排冷水下锅加料酒和姜片焯水，捞出洗净。",
    "锅中放少许油，加白糖小火炒至焦糖色。",
    "放入排骨翻炒上色。",
    "加入生抽、料酒、番茄酱翻炒均匀。",
    "加入没过排骨的热水，大火烧开后转小火炖30分钟。",
    "开盖加入香醋，大火收汁至浓稠。",
    "撒白芝麻装盘。"
  ],
  "tips": "醋要最后加，太早加会挥发掉酸味；收汁时要不停翻动防止粘锅。"
}