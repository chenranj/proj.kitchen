{
  "id": "玉米排骨汤",
  "name": "玉米排骨汤",
  "category": "汤与粥",
  "difficulty": "中等",
  "tools": [
    "炒锅",
    "砂锅"
  ],
  "ingredients": [
    {
      "name": "排骨",
      "amount": "500-800g"
    },
    {
      "name": "玉米一根（喜欢吃玉米的可以多一根）",
      "amount": "适量"
    },
    {
      "name": "胡萝卜一根（喜欢吃胡箩卜的可以多一根）",
      "amount": "适量"
    },
    {
      "name": "大葱小半根",
      "amount": "适量"
    },
    {
      "name": "香葱一根",
      "amount": "适量"
    },
    {
      "name": "食用油",
      "amount": "10 ml"
    },
    {
      "name": "黑胡椒粉",
      "amount": "4g"
    },
    {
      "name": "料酒",
      "amount": "10ml"
    },
    {
      "name": "醋",
      "amount": "10ml"
    },
    {
      "name": "食用盐",
      "amount": "10-15g（根据最后汤剩余的量而定）"
    },
    {
      "name": "开水",
      "amount": "1000 ml"
    }
  ],
  "steps": [
    "大葱切成 3-4cm 的大段，用刀背拍一下",
    "玉米剁成小块",
    "胡箩卜切成滚刀块",
    "生姜去皮切大片",
    "新鲜的排骨砍成小块",
    "排骨凉水下锅，放入大葱、生姜、料酒开始焯水，大火烧开，撇去浮沫，捞出排骨，沥干水分",
    "热锅凉油，切大片的生姜和排骨一起下锅煸炒，待排骨表面微微焦黄，放入醋（可加速肉质软烂），继续煸炒一分钟",
    "冲入开水，一次给足，之后就不要再加了，大火烧开",
    "先下入玉米，放入胡椒粉，盖盖小火炖二十分钟，然后放入胡萝卜，盖盖继续小火炖四十分钟",
    "调味很简单，出锅前三分钟，除了盐什么都不用放，最后撒上一把小葱花即可"
  ]
}