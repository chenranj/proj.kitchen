  ],
  "ingredients": [
    {
      "name": "红薯粉丝",
      "amount": "80g（干重）"
    },
    {
      "name": "猪肉末",
      "amount": "150g"
    },
    {
      "name": "郫县豆瓣酱",
      "amount": "15g"
    },
    {
      "name": "生抽",
      "amount": "10ml"
    },
    {
      "name": "老抽",
      "amount": "5ml"
    },
    {
      "name": "食用油",
      "amount": "10ml"
    },
    {
      "name": "蒜末",
      "amount": "10g"
    },
    {
      "name": "姜末",
      "amount": "5g"
    },
    {
      "name": "清水",
      "amount": "300ml（用于煮粉丝）"
    }
  ],
  "steps": [
    "红薯粉丝提前泡软，泡水时间为 20 分钟，备用",
    "将蒜、姜分别剁碎，备用",
    "锅烧热，加入 10ml 食用油，加入蒜末、姜末炒香",
    "加入猪肉末翻炒至**肉色发白且微微出油**",
    "加入郫县豆瓣酱，炒至**红油析出**",
    "加入生抽和老抽，翻炒均匀",
    "倒入 300ml 清水，煮沸",
    "放入泡软沥干的粉丝，用筷子轻轻拨动防止粘连",
    "中小火煮约 5 分钟，直至粉丝**完全吸收汤汁**、呈现微微收干状态",
    "依据口味可撒入小葱末，关火装盘"
  ],
  "tips": "粉丝不建议煮太久，易断且口感变差；若时间过长汤汁应适当减少；郫县豆瓣酱含盐量较高，可根据口味酌情减少生抽用量；可加入 0.5g 白胡椒粉调味，风味更佳"
}