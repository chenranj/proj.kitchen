      "name": "鸡蛋",
      "amount": "2 个"
    },
    {
      "name": "饮用水",
      "amount": "35ml"
    },
    {
      "name": "芝麻油",
      "amount": "3ml"
    },
    {
      "name": "盐",
      "amount": "0.8g"
    }
